# =============================================================================
# TransLlama 环境变量配置
# 复制此文件为 .env 并修改对应值
# =============================================================================

# ---------- 认证 ----------
# API Key 列表，逗号分隔。客户端通过 Authorization: Bearer <key> 认证
API_KEYS=test_key_1,test_key_2,test_key_3

# ---------- 模型 ----------
# 默认使用的模型（对应 models.yaml 中的 name 字段）
DEFAULT_MODEL=hy-mt-general
# 默认模型不可用时的备选模型
FALLBACK_MODEL=hy-mt-general

# ---------- 限流 ----------
# 每个 API Key 每分钟最大请求数
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ---------- 存储 ----------
# 模型文件存储目录
MODEL_STORAGE_PATH=./storage/models
# 模型配置文件路径
MODELS_CONFIG_PATH=./models.yaml

# ---------- 服务 ----------
# 监听地址
HOST=0.0.0.0
# 监听端口
PORT=8000
# Uvicorn worker 数量（翻译模型较大，建议保持 1）
WORKERS=1

# ---------- 日志 ----------
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
